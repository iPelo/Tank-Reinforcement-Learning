{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Train Hidden-Info 1v1",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "-m",
        "src.scripts.train",
        "--phase",
        "2",
        "--single-phase",
        "--layout",
        "1v1",
        "--pool-opponent-prob",
        "0",
        "--self-play-prob",
        "1"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Train Team Self-Play 2v2",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "-m",
        "src.scripts.train",
        "--phase",
        "2",
        "--single-phase",
        "--layout",
        "2v2",
        "--pool-opponent-prob",
        "0",
        "--self-play-prob",
        "1"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Quick Eval 1v1",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "-m",
        "src.scripts.eval",
        "--phase",
        "2",
        "--layout",
        "1v1",
        "--episodes",
        "3"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Render Eval 1v1",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "-m",
        "src.scripts.eval",
        "--phase",
        "2",
        "--layout",
        "1v1",
        "--episodes",
        "10",
        "--render"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Render Eval 2v2",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "-m",
        "src.scripts.eval",
        "--phase",
        "2",
        "--layout",
        "2v2",
        "--episodes",
        "10",
        "--render"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Checkpoint Match Eval",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "-m",
        "src.scripts.match_eval",
        "--player-model",
        "src/scripts/models/ppo_phase2_last.pt",
        "--enemy-model",
        "src/scripts/models/ppo_phase2_last.pt",
        "--phase",
        "2"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "League Report",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "-m",
        "src.scripts.league_report",
        "--current-model",
        "src/scripts/models/ppo_phase2_last.pt",
        "--phase",
        "2",
        "--episodes",
        "12"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Validate Baseline",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "-m",
        "src.scripts.validate_baseline",
        "--candidate-model",
        "src/scripts/models/ppo_phase2_last.pt",
        "--baseline-model",
        "src/scripts/models/ppo_phase2_best.pt",
        "--phase",
        "2",
        "--episodes",
        "12"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
