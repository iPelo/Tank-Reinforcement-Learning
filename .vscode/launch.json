{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Train Self-Play Curriculum",
      "type": "python",
      "request": "launch",
      "python": "${workspaceFolder}/.venv/bin/python",
      "module": "src.scripts.train",
      "args": [],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Train Self-Play Phase 2",
      "type": "python",
      "request": "launch",
      "python": "${workspaceFolder}/.venv/bin/python",
      "module": "src.scripts.train",
      "args": ["--phase", "2", "--single-phase"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Quick Eval Self-Play",
      "type": "python",
      "request": "launch",
      "python": "${workspaceFolder}/.venv/bin/python",
      "module": "src.scripts.eval",
      "args": ["--phase", "2", "--episodes", "1"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Render Eval Self-Play",
      "type": "python",
      "request": "launch",
      "python": "${workspaceFolder}/.venv/bin/python",
      "module": "src.scripts.eval",
      "args": ["--phase", "2", "--episodes", "10", "--render"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    }
  ]
}
