{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Train Self-Play Curriculum",
      "type": "python",
      "request": "launch",
      "python": "${workspaceFolder}/.venv/bin/python",
      "module": "src.scripts.train",
      "args": [],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Train Hidden-Info Phase 2",
      "type": "python",
      "request": "launch",
      "python": "${workspaceFolder}/.venv/bin/python",
      "module": "src.scripts.train",
      "args": ["--phase", "2", "--single-phase"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Quick Eval Hidden-Info",
      "type": "python",
      "request": "launch",
      "python": "${workspaceFolder}/.venv/bin/python",
      "module": "src.scripts.eval",
      "args": ["--phase", "2", "--episodes", "1"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Render Eval Hidden-Info",
      "type": "python",
      "request": "launch",
      "python": "${workspaceFolder}/.venv/bin/python",
      "module": "src.scripts.eval",
      "args": ["--phase", "2", "--episodes", "10", "--render"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Checkpoint Match Eval",
      "type": "python",
      "request": "launch",
      "python": "${workspaceFolder}/.venv/bin/python",
      "module": "src.scripts.match_eval",
      "args": [
        "--player-model",
        "src/scripts/models/ppo_phase2_last.pt",
        "--enemy-model",
        "src/scripts/models/ppo_phase2_last.pt",
        "--phase",
        "2",
        "--episodes",
        "10"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "League Report",
      "type": "python",
      "request": "launch",
      "python": "${workspaceFolder}/.venv/bin/python",
      "module": "src.scripts.league_report",
      "args": [
        "--current-model",
        "src/scripts/models/ppo_phase2_last.pt",
        "--phase",
        "2",
        "--episodes",
        "12"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    }
  ]
}
