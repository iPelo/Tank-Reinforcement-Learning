{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Train Hidden-Info 1v1",
      "type": "python",
      "request": "launch",
      "python": "${workspaceFolder}/.venv/bin/python",
      "module": "src.scripts.train",
      "args": [
        "--phase",
        "2",
        "--single-phase",
        "--layout",
        "1v1",
        "--pool-opponent-prob",
        "0",
        "--self-play-prob",
        "1"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Train Team Self-Play 2v2",
      "type": "python",
      "request": "launch",
      "python": "${workspaceFolder}/.venv/bin/python",
      "module": "src.scripts.train",
      "args": [
        "--phase",
        "2",
        "--single-phase",
        "--layout",
        "2v2",
        "--pool-opponent-prob",
        "0",
        "--self-play-prob",
        "1"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Quick Eval 1v1",
      "type": "python",
      "request": "launch",
      "python": "${workspaceFolder}/.venv/bin/python",
      "module": "src.scripts.eval",
      "args": [
        "--phase",
        "2",
        "--layout",
        "1v1",
        "--episodes",
        "3"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Render Eval 1v1",
      "type": "python",
      "request": "launch",
      "python": "${workspaceFolder}/.venv/bin/python",
      "module": "src.scripts.eval",
      "args": [
        "--phase",
        "2",
        "--layout",
        "1v1",
        "--episodes",
        "10",
        "--render"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Render Eval 2v2",
      "type": "python",
      "request": "launch",
      "python": "${workspaceFolder}/.venv/bin/python",
      "module": "src.scripts.eval",
      "args": [
        "--phase",
        "2",
        "--layout",
        "2v2",
        "--episodes",
        "10",
        "--render"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Checkpoint Match Eval",
      "type": "python",
      "request": "launch",
      "python": "${workspaceFolder}/.venv/bin/python",
      "module": "src.scripts.match_eval",
      "args": [
        "--player-model",
        "src/scripts/models/ppo_phase2_last.pt",
        "--enemy-model",
        "src/scripts/models/ppo_phase2_last.pt",
        "--phase",
        "2"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "League Report",
      "type": "python",
      "request": "launch",
      "python": "${workspaceFolder}/.venv/bin/python",
      "module": "src.scripts.league_report",
      "args": [
        "--current-model",
        "src/scripts/models/ppo_phase2_last.pt",
        "--phase",
        "2",
        "--episodes",
        "12"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Validate Baseline",
      "type": "python",
      "request": "launch",
      "python": "${workspaceFolder}/.venv/bin/python",
      "module": "src.scripts.validate_baseline",
      "args": [
        "--candidate-model",
        "src/scripts/models/ppo_phase2_last.pt",
        "--baseline-model",
        "src/scripts/models/ppo_phase2_best.pt",
        "--phase",
        "2",
        "--episodes",
        "12"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
